# Local model used via Ollama (default when no OpenAI key is set)
LLM_MODEL=qwen2.5:14b

# Local embedding model used via Ollama (multilingual, 768-dim).
# Changing this changes vector dimensionality -> wipe/re-index .chroma_db.
EMBED_MODEL=nomic-embed-text

# Chunking of long notes before embedding (sizes in words).
CHUNK_SIZE=600
CHUNK_OVERLAP=80

# Optional — set to route agents through OpenAI instead of Ollama.
# Leave blank to stay 100% local / privacy-first.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
